# ============================================================
# MedgeClaw — 环境配置
# 复制此文件: cp .env.example .env
# 然后填写你的配置
# ============================================================

# ── 项目路径（可选，默认自动检测）────────────────────────────
# 通常无需设置，sync.py 会自动检测
# MEDGECLAW_ROOT=/path/to/MedgeClaw
# OPENCLAW_DIR=$HOME/.openclaw

# Docker 容器名称
DOCKER_CONTAINER=medgeclaw

# ── Model Provider (choose one) ──────────────────────────────
# Option 1: Anthropic Claude (default)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
MODEL=claude-sonnet-4-6

# Option 2: MiniMax (国内平替)
# ANTHROPIC_API_KEY=your_minimax_api_key
# ANTHROPIC_BASE_URL=https://api.minimax.chat/anthropic
# MODEL=minimax-2.1

# Option 3: GLM (智谱 Z.ai)
# ANTHROPIC_API_KEY=your_zai_api_key
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL=glm-4.7

# Option 4: DeepSeek
# ANTHROPIC_API_KEY=your_deepseek_api_key
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL=deepseek-chat

# Option 5: Local model via Ollama
# ANTHROPIC_API_KEY=ollama
# ANTHROPIC_BASE_URL=http://localhost:11434/v1
# MODEL=qwen2.5:14b

# ── Third-Party API Proxy Fix (Required!) ─────────────────────
# Claude Code uses a lightweight model (claude-3-5-haiku) for internal
# pre-flight checks before running bash commands. Most third-party
# proxies don't support Haiku, causing Claude Code to hang.
#
# If using ANY non-Anthropic API endpoint, uncomment and set this
# to a model your proxy supports:
# ANTHROPIC_SMALL_FAST_MODEL=claude-sonnet-4-20250514

# ── Web Interface Passwords ───────────────────────────────────
RSTUDIO_PASSWORD=biomed
JUPYTER_TOKEN=biomed

# ── K-Dense Scientific Skills API Keys (optional) ────────────
# Fill in only the ones you need.
# Each K-Dense skill's SKILL.md lists which keys it requires.

# Literature & Databases
NCBI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Chemistry & Drug Discovery
CHEMBL_API_KEY=

# Clinical
CLINICALTRIALS_API_KEY=

# Cloud compute (optional, for heavy workloads)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# AI image generation (for scientific figures)
OPENAI_API_KEY=

# ── ClawBio Skills (optional) ────────────────────────────────
# Galaxy Bridge — access 8000+ bioinformatics tools
GALAXY_URL=https://usegalaxy.org
GALAXY_API_KEY=

# ── Feishu Integration (optional) ────────────────────────────
# Default chat ID for feishu-rich-card skill
FEISHU_DEFAULT_CHAT_ID=
